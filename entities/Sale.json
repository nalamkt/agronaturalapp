{
  "name": "Sale",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "ID del cliente"
    },
    "client_name": {
      "type": "string",
      "description": "Nombre del cliente (para referencia r\u00e1pida)"
    },
    "items": {
      "type": "array",
      "description": "Art\u00edculos de la venta",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "subtotal": {
            "type": "number"
          }
        }
      }
    },
    "total": {
      "type": "number",
      "description": "Total de la venta"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendiente",
        "cobrada",
        "cuenta_corriente"
      ],
      "default": "pendiente",
      "description": "Estado de la venta"
    },
    "notes": {
      "type": "string",
      "description": "Notas de la venta"
    },
    "sale_date": {
      "type": "string",
      "format": "date",
      "description": "Fecha de la venta"
    }
  },
  "required": [
    "client_id",
    "items",
    "total"
  ]
}